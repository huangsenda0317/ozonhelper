# 生产环境配置（复制为 backend/.env 部署到服务器）
# 本地开发请使用 .env.development.example

# 生产环境：配置公网域名后预签名 URL 自动使用 www.ozonhelper.com
# APP_ENV=production  # 可选，与留空等价；有 MINIO_PUBLIC_ENDPOINT 即走公网

DATABASE_URL=postgresql+asyncpg://ozonhelper:ozonhelper@localhost:5432/ozonhelper

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=86400

# Ozon Seller API（凭证在「设置 → Ozon 店铺管理」页面绑定，不再写入此处）
OZON_API_BASE_URL=https://api-seller.ozon.ru

# 火山引擎 SeedEdit 3.0 (AI 改图)
VOLCENGINE_ACCESS_KEY_ID=AKLT...
VOLCENGINE_SECRET_ACCESS_KEY=...
VOLCENGINE_REGION=cn-north-1
VOLCENGINE_SERVICE=cv
VOLCENGINE_SEEDEDIT_REQ_KEY=seededit_v3.0
VOLCENGINE_SEEDEDIT_CONCURRENCY=2

# 腾讯云机器翻译 TMT (AI 翻译)
TENCENT_SECRET_ID=AKID...
TENCENT_SECRET_KEY=...
TENCENT_TMT_REGION=ap-guangzhou
TENCENT_TMT_PROJECT_ID=0

# 图片存储 (MinIO/S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ozonhelper-images
# 生产环境：浏览器访问图片的公网域名（须与 Nginx 反代 MinIO 的 server_name 一致）
MINIO_PUBLIC_ENDPOINT=www.ozonhelper.com
MINIO_PUBLIC_SECURE=false

# 加密密钥
ENCRYPTION_KEY=your-fernet-key-change-in-production
